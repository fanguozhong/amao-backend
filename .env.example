# 阿猫阿狗后端环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务配置
PORT=3000
NODE_ENV=production

# JWT密钥 (必须设置，使用 openssl rand -hex 32 生成)
JWT_SECRET=

# 数据库配置
DB_HOST=localhost
DB_USER=amao
DB_PASSWORD=
DB_NAME=amao

# 短信配置 (可选)
SMS_ENDPOINT=https://api.ucpaas.com
SMS_ACCOUNT_SID=
SMS_ACCOUNT_TOKEN=
SMS_APP_ID=

# 融云IM配置 (可选)
RONGCLOUD_APP_KEY=
RONGCLOUD_APP_SECRET=
RONGCLOUD_API_URL=http://api.rong.io

# 高德地图配置 (可选)
AMAP_KEY=

# 微信登录配置 (可选)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

# 微博登录配置 (可选)
WEIBO_APP_KEY=
WEIBO_APP_SECRET=
WEIBO_REDIRECT_URI=
